# GeoGebra 本地服务器地址
# 选项1：使用独立部署的 GeoGebra 服务器（推荐）
# VITE_GEOGEBRA_SERVER_URL=http://10.50.43.173:8080/geogebra.html

# 选项2：使用项目内置的 GeoGebra（需要执行 npm run copy:geogebra 复制文件）
# VITE_GEOGEBRA_SERVER_URL=/geogebra/geogebra.html

# 如果留空，则使用 /geogebra/geogebra.html（需要先执行 npm run copy:geogebra）
VITE_GEOGEBRA_SERVER_URL=http://10.50.43.173:8080/geogebra.html
# 存储 key 前缀
VITE_STORAGE_KEY_PREFIX=mlt_

# DeepSeek API 配置
VITE_DEEPSEEK_API_BASE_URL=https://api.deepseek.com
VITE_DEEPSEEK_MODEL=deepseek-chat
# 应用标题
VITE_APP_TITLE=高数函数图像解题工具

# 最大对话数量
VITE_MAX_CHAT_COUNT=10
# 每个对话最大消息数
VITE_MAX_MESSAGES_PER_CHAT=100
